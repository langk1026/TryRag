# Runtime Environment
ENVIRONMENT=development

# Local Document Source (used when ENVIRONMENT=development)
LOCAL_DOCUMENTS_PATH=/tmp/tryrag_documents

# SharePoint Configuration
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/yoursite
SHAREPOINT_CLIENT_ID=your_client_id
SHAREPOINT_CLIENT_SECRET=your_client_secret
SHAREPOINT_TENANT_ID=your_tenant_id
SHAREPOINT_DOCUMENT_LIBRARY=Shared Documents

# OpenAI Configuration (for embeddings and LLM)
GOOGLE_API_KEY=your_google_ai_studio_api_key
EMBEDDING_MODEL=gemini-embedding-2-preview
LLM_MODEL=gemini-3.1-flash-lite-preview

# Vector Database Configuration
VECTOR_DB_PATH=./data/chromadb
COLLECTION_NAME=sharepoint_documents

# Indexing Configuration
INDEX_SCHEDULE_MINUTES=30
BATCH_SIZE=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=http://localhost:3000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Advanced RAG Features
HYDE_ENABLED=true
HYDE_TEMPERATURE=0.7
HYDE_MAX_TOKENS=300

# Docker Configuration (for containerized deployment)
# Use service names for inter-container communication
# Example: VECTOR_DB_PATH=/app/data/chromadb (inside container)
